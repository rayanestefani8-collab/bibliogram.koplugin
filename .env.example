# Credenciais do Telegram (obtém em https://my.telegram.org/apps)
TG_API_ID=seu_api_id
TG_API_HASH=seu_api_hash
TG_PHONE=+55999999999
TG_BOT_TOKEN=

# Configuração da aplicação
FLASK_ENV=production
SERVER_PORT=8081
WEBAPP_PORT=8082

# Sincronização
SYNC_INTERVAL=900  # segundos (15 minutos)

# Opções de processamento
DOWNLOAD_COVERS=true
FIX_TITLES=true
